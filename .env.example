# =====================================================
# IP+MP Platform — Variables de entorno
# =====================================================
# IMPORTANTE: Este archivo es solo de ejemplo. NO contiene secretos reales.
# El archivo real se llama .env.local (en desarrollo) o se configura en Vercel
# (en producción). Nunca commites el .env real al repositorio.
# =====================================================

# --- Base de datos PostgreSQL ---
# Railway te entrega esta cadena cuando creas la base de datos.
# Formato: postgresql://usuario:password@host:puerto/nombredb
DATABASE_URL="postgresql://postgres:password@localhost:5432/ipmp"

# --- Token de administración ---
# String aleatorio largo para proteger las rutas /api/admin/*
# Generá uno con: https://1password.com/password-generator/ (mín 32 caracteres)
ADMIN_TOKEN="reemplazar-por-string-aleatorio-largo-de-al-menos-32-caracteres"

# --- API de Anthropic (Claude) ---
# NO NECESARIO EN FASE 0. Dejar vacío hasta que arranquemos Fase 1.
ANTHROPIC_API_KEY=""

# --- URL de la aplicación ---
# En desarrollo: http://localhost:3000
# En producción: Vercel la setea automáticamente, no toques esto allá
NEXT_PUBLIC_APP_URL="http://localhost:3000"
